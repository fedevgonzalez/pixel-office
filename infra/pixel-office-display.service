[Unit]
Description=Pixel Office Wall Display Monitor
After=network-online.target pixel-office-server.service
Wants=network-online.target pixel-office-server.service

[Service]
Type=simple
User=root
ExecStart=/home/fedev/homeserver/scripts/pixel-office-display.sh
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Cap memory at 2GB — prevents OOM killer from affecting other services
MemoryMax=2G
MemoryHigh=1536M

[Install]
WantedBy=multi-user.target
