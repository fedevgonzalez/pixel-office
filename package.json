{
  "name": "pixel-office",
  "displayName": "Pixel Office",
  "description": "Real-time visual dashboard for Claude Code agents — standalone web server with pixel art office",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fedevgonzalez/pixel-office"
  },
  "icon": "icon.png",
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build:webview": "cd webview-ui && pnpm build",
    "build": "pnpm build:webview",
    "compile": "pnpm check-types && pnpm lint && pnpm build:webview",
    "watch": "cd webview-ui && pnpm dev",
    "check-types": "cd webview-ui && pnpm exec tsc --noEmit",
    "lint": "cd webview-ui && pnpm lint",
    "import-tileset": "tsx scripts/0-import-tileset.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@types/node": "22.x",
    "@types/pngjs": "^6.0.5",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "gifenc": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}
